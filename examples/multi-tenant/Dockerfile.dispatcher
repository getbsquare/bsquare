FROM python:3.12-slim
WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir "pydantic-ai" "uvicorn[standard]" "starlette<1.0" "httpx"

# Copy the dispatcher code
COPY examples/multi-tenant/dispatcher.py /app/dispatcher.py

# Expose the port
EXPOSE 8000

# Run the dispatcher
CMD ["uvicorn", "dispatcher:app", "--host", "0.0.0.0", "--port", "8000"]
