# Get a Gemini key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here
# Optional: override the model, e.g. openai:gpt-4o-mini (also set the matching key)
# BSQUARE_MODEL=google-gla:gemini-2.5-flash

# --- Ollama (local or Cloud) ---
# Local Ollama (from Docker on Linux, also uncomment extra_hosts in docker-compose.yml):
#   OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
#   BSQUARE_MODEL=llama3.1
# Ollama Cloud (confirm the base URL from your account):
#   OLLAMA_BASE_URL=https://ollama.com/v1
#   OLLAMA_API_KEY=your-ollama-cloud-key
#   BSQUARE_MODEL=gpt-oss:120b
# The chosen model MUST support tool calling, or host actions will not fire.
# OLLAMA_BASE_URL=
# OLLAMA_API_KEY=
