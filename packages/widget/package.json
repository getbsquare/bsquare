{
  "name": "bsquare-widget",
  "version": "0.1.0",
  "description": "Injectable AI chat widget with host-action support for AG-UI / PydanticAI backends",
  "repository": {
    "type": "git",
    "url": "https://github.com/getbsquare/bsquare",
    "directory": "packages/widget"
  },
  "homepage": "https://github.com/getbsquare/bsquare/tree/main/packages/widget",
  "bugs": {
    "url": "https://github.com/getbsquare/bsquare/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./global": "./dist/bsquare-widget.global.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.cjs",
    "./dist/bsquare-widget.global.js"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^25.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
